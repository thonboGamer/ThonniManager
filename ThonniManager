    animateOrb(orb, cfg)
end

-- Floating particles
local particleColors = {
    Color3.fromRGB(140, 90, 255),
    Color3.fromRGB(100, 60, 220),
    Color3.fromRGB(180, 120, 255),
    Color3.fromRGB(80, 50, 200),
}

local function spawnParticle()
    local size = math.random(3, 7)
    local p = Instance.new("Frame", bgFrame)
    p.Size             = UDim2.new(0, size, 0, size)
    p.Position         = UDim2.new(math.random(), 0, 1.05, 0)
    p.BackgroundColor3 = particleColors[math.random(#particleColors)]
    p.BackgroundTransparency = math.random(55, 80) / 100
    p.BorderSizePixel  = 0
    p.ZIndex           = 2
    Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)

    local targetX   = math.random() + (math.random()-0.5)*0.3
    local duration  = math.random(40, 90) / 10

    -- float up
    TweenService:Create(p,
        TweenInfo.new(duration, Enum.EasingStyle.Linear),
        {Position = UDim2.new(targetX, 0, -0.05, 0)}
    ):Play()

    -- flicker transparency
    task.spawn(function()
        while p.Parent do
            local tr = math.random(50, 85) / 100
            TweenService:Create(p,
                TweenInfo.new(math.random(8,20)/10, Enum.EasingStyle.Sine),
                {BackgroundTransparency = tr}
            ):Play()
            task.wait(math.random(8, 20) / 10)
        end
    end)

    task.delay(duration, function()
        if p and p.Parent then p:Destroy() end
        task.wait(math.random(5, 20) / 10)
        spawnParticle()
    end)
end

-- Spawn initial particles
