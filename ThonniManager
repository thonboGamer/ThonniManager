    {startX=0.78, startY=0.55, size=170, color=Color3.fromRGB(100,20,180), transparency=0.90, duration=8},
    {startX=0.45, startY=0.85, size=150, color=Color3.fromRGB(40,20,140),  transparency=0.91, duration=7},
    {startX=0.88, startY=0.18, size=130, color=Color3.fromRGB(80,20,200),  transparency=0.92, duration=5},
}

local function animateOrb(orb, cfg)
    local offsets = {
        {dx=0.12, dy=-0.10},
        {dx=-0.08, dy=0.15},
        {dx=0.06,  dy=0.08},
        {dx=-0.12, dy=-0.06},
    }
    local i = 0
    local function nextTween()
        i = (i % #offsets) + 1
        local o = offsets[i]
        local newX = math.clamp(cfg.startX + o.dx + (math.random()-0.5)*0.06, 0.05, 0.92)
        local newY = math.clamp(cfg.startY + o.dy + (math.random()-0.5)*0.06, 0.05, 0.92)
        local dur  = cfg.duration + (math.random()-0.5)*2
        local t = TweenService:Create(orb,
            TweenInfo.new(dur, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
            {Position = UDim2.new(newX, -cfg.size/2, newY, -cfg.size/2)}
        )
        t.Completed:Connect(nextTween)
        t:Play()
    end
    nextTween()

    -- pulse transparency
    task.spawn(function()
        while orb.Parent do
            TweenService:Create(orb,
                TweenInfo.new(cfg.duration*0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = cfg.transparency - 0.04}
            ):Play()
            task.wait(cfg.duration*0.6)
            TweenService:Create(orb,
                TweenInfo.new(cfg.duration*0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {BackgroundTransparency = cfg.transparency + 0.02}
            ):Play()
            task.wait(cfg.duration*0.6)
        end
    end)
end

for _, cfg in orbConfigs do
    local orb = Instance.new("Frame", bgFrame)
