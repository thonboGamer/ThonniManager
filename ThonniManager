-- Nav item builder
local function makeNav(label, icon, yPos, pageName)
    local row = Instance.new("Frame", sidebar)
    row.Size             = UDim2.new(1, 0, 0, 38)
    row.Position         = UDim2.new(0, 0, 0, yPos)
    row.BackgroundColor3 = Color3.fromRGB(9, 7, 22)
    row.BorderSizePixel  = 0
    row.ZIndex           = 5

    local accent = Instance.new("Frame", row)
    accent.Size             = UDim2.new(0, 3, 0, 22)
    accent.Position         = UDim2.new(0, 0, 0.5, -11)
    accent.BackgroundColor3 = Color3.fromRGB(120, 80, 255)
    accent.BackgroundTransparency = 1
    accent.BorderSizePixel  = 0
    accent.ZIndex           = 5
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 2)

    local icoL = Instance.new("TextLabel", row)
    icoL.Size             = UDim2.new(0, 22, 1, 0)
    icoL.Position         = UDim2.new(0, 12, 0, 0)
    icoL.BackgroundTransparency = 1
    icoL.Text             = icon
    icoL.TextSize         = 14
    icoL.Font             = Enum.Font.GothamBold
    icoL.TextColor3       = Color3.fromRGB(55, 44, 88)
    icoL.TextXAlignment   = Enum.TextXAlignment.Center
    icoL.ZIndex           = 5

    local nameL = Instance.new("TextLabel", row)
    nameL.Size             = UDim2.new(1, -44, 1, 0)
    nameL.Position         = UDim2.new(0, 38, 0, 0)
    nameL.BackgroundTransparency = 1
    nameL.Text             = label
    nameL.TextSize         = 11
    nameL.Font             = Enum.Font.GothamMedium
    nameL.TextColor3       = Color3.fromRGB(55, 44, 88)
    nameL.TextXAlignment   = Enum.TextXAlignment.Left
    nameL.ZIndex           = 5

    local btn = Instance.new("TextButton", row)
    btn.Size               = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text               = ""
    btn.ZIndex             = 6

    local function activate()
        if activeNavRef then
            tw(activeNavRef.accent, {BackgroundTransparency = 1})
            tw(activeNavRef.icoL,   {TextColor3 = Color3.fromRGB(55, 44, 88)})
            tw(activeNavRef.nameL,  {TextColor3 = Color3.fromRGB(55, 44, 88)})
            tw(activeNavRef.row,    {BackgroundColor3 = Color3.fromRGB(9, 7, 22)})
        end
        tw(accent, {BackgroundTransparency = 0})
        tw(icoL,   {TextColor3 = Color3.fromRGB(160, 120, 255)})
        tw(nameL,  {TextColor3 = Color3.fromRGB(200, 180, 255)})
        tw(row,    {BackgroundColor3 = Color3.fromRGB(20, 14, 40)})
        activeNavRef = {row=row, accent=accent, icoL=icoL, nameL=nameL}
        showPage(pageName)
    end

    btn.MouseButton1Click:Connect(activate)
    btn.MouseEnter:Connect(function()
        if not activeNavRef or activeNavRef.row ~= row then
            tw(row, {BackgroundColor3 = Color3.fromRGB(14, 11, 30)})
        end
    end)
    btn.MouseLeave:Connect(function()
        if not activeNavRef or activeNavRef.row ~= row then
            tw(row, {BackgroundColor3 = Color3.fromRGB(9, 7, 22)})
        end
    end)

    return activate
end

