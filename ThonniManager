task.spawn(function()
    while true do
        if state.autoMerge then
            local nukes = GetMyNukes()
            if not nukes then task.wait(CFG.SCAN_DELAY) continue end
            local a, b = FindPair(nukes)
            if not a then
                state.isFloating = true
                state.idlePos    = PadCenter(nukes)
                DropNuke()
                task.wait(CFG.SCAN_DELAY)
                continue
            end
            state.isFloating = false
            DropNuke()
            local fp = PadCenter(nukes)
            if fp then TP(fp); task.wait(0.2) end
            TP(a.Position); task.wait(CFG.PICKUP_WAIT)
            if b and b.Parent then
                TP(b.Position); task.wait(CFG.MERGE_WAIT)
            else
                DropNuke()
            end
        else
            state.isFloating = false
            task.wait(0.5)
        end
    end
end)

