local function GetMyNukes()
    local char = LocalPlayer.Character
    if not char then return nil end
    local myPos = char.HumanoidRootPart.Position
    local best, bd = nil, math.huge
    for _, base in game.Workspace.Bases:GetChildren() do
        local nukes = base:FindFirstChild("Nukes")
        if nukes then
            for _, nuke in nukes:GetChildren() do
                local d = (nuke.Position - myPos).Magnitude
                if d < bd then bd = d; best = nukes end
            end
        end
    end
    return best
end

local function FindPair(nukes)
    local g = {}
    for _, nuke in nukes:GetChildren() do
        local t = nuke:GetAttribute("Tier")
        if t then
            if not g[t] then g[t] = {} end
            table.insert(g[t], nuke)
        end
    end
    local lt, pair = math.huge, nil
    for t, list in g do
        if #list >= 2 and t < lt then lt = t; pair = list end
    end
    if pair then return pair[1], pair[2] end
end

local function PadCenter(nukes)
    local total, c = Vector3.zero, 0
    for _, n in nukes:GetChildren() do total += n.Position; c += 1 end
    if c == 0 then return nil end
    local v = total / c
    return Vector3.new(v.X, v.Y + CFG.FLOAT_HEIGHT, v.Z)
end

local function TP(pos)
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    root.CFrame                  = CFrame.new(pos)
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
end

local function DropNuke()
    local char = LocalPlayer.Character
    if not char then return end
    Drop:FireServer(CFrame.new(char.HumanoidRootPart.Position))
    task.wait(0.2)
end

